# =============================================================================
# FilmiFy — Environment variables template
# Copy this file to `.env.local` and fill in the values.
# Restart `npm run dev` after creating or editing `.env.local`.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Content provider (TMDB)
# Without this key, movie/TV features degrade to empty lists.
# Get a free key at: https://www.themoviedb.org/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here
TMDB_API_KEY=your_tmdb_api_key_here

# -----------------------------------------------------------------------------
# REQUIRED IN PRODUCTION — Supabase (auth, favorites, admin, etc.)
# Create a project at: https://supabase.com
# Without these, auth-gated routes redirect to `/` and DB calls no-op.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
# Server-only — never expose to client bundles.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# -----------------------------------------------------------------------------
# OPTIONAL — Vimeus embed player (sin anuncios)
# view_key: pública, va en el iframe (valida dominio)
# api_key: privada, solo backend (listados)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VIMEUS_VIEW_KEY=your_vimeus_view_key_here
VIMEUS_API_KEY=your_vimeus_api_key_here

# -----------------------------------------------------------------------------
# OPTIONAL — AI recommendations
# -----------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# -----------------------------------------------------------------------------
# OPTIONAL — Contact form (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=your_resend_api_key_here

# -----------------------------------------------------------------------------
# OPTIONAL — Cron job auth token (used by /api/cron/*)
# Generate a random value: `openssl rand -hex 32`
# -----------------------------------------------------------------------------
CRON_SECRET=your_cron_secret_here

# -----------------------------------------------------------------------------
# OPTIONAL — STB portal device secret (used to derive per-device passwords)
# Generate a random value: `openssl rand -hex 32`
# Without this, STB device authentication is disabled.
# -----------------------------------------------------------------------------
PORTAL_DEVICE_SECRET=your_portal_device_secret_here

# -----------------------------------------------------------------------------
# OPTIONAL — Anti-bot on auth forms (hCaptcha)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key_here

# -----------------------------------------------------------------------------
# OPTIONAL — Analytics & ads
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# -----------------------------------------------------------------------------
# OPTIONAL — Public base URL (used by sitemap, emails, OG tags)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
